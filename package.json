{
  "name": "rabit-core",
  "version": "0.1.0",
  "description": "Ra-Bit Core - Multi-Agent Swarm Orchestrator for local Ollama models",
  "main": "dist/cli.js",
  "bin": {
    "rabit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/cli.ts",
    "dev": "ts-node src/cli.ts",
    "clean": "rm -rf dist",
